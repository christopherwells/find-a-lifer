rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: anyone authenticated can read, only owner can write
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;

      // Friends subcollection: owner can read/write, friend being added can write (for accept)
      match /friends/{friendId} {
        allow read: if request.auth.uid == uid;
        allow write: if request.auth.uid == uid || request.auth.uid == friendId;
      }

      // Trip reports: anyone authenticated can read public ones, owner writes
      match /tripReports/{reportId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == uid;
      }
    }

    // Friend requests: sender can create, recipient can read/update
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUid;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid
      );
      allow update: if request.auth != null && request.auth.uid == resource.data.toUid;
    }

    // Shared goal lists: read if in sharedWith, write if owner
    match /sharedGoalLists/{listId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.sharedWith;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
    }
  }
}
